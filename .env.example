# Project: DeepMediaCheck Configuration Template

# API Server Settings
PROJECT_NAME="DeepMediaCheck"
API_V1_STR="/api/v1"
VERSION="0.1.0"

# CORS Settings (Allow frontend access)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Signal Fusion Weights (Must sum to ~1.0 generally, but logic handles normalization)
WEIGHT_METADATA=0.3
WEIGHT_ARTIFACTS=0.3
WEIGHT_CLASSIFIER=0.4

# Explanation Layer (Optional)
# Get a key from AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=""
ENABLE_LLM_EXPLANATIONS=False
